{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "PracticeADFprojects"
		},
		"AzureBlobStorage1_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'AzureBlobStorage1'"
		},
		"AzureDataLakeStorage1_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'AzureDataLakeStorage1'"
		},
		"SQL_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'SQL'"
		},
		"project_lochan_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'project_lochan'"
		},
		"AzureDataLakeStorage1_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://practiceadfproject.dfs.core.windows.net/"
		},
		"SQL_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "DESKTOP-LOCHANK\\SQLEXPRESS"
		},
		"SQL_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "employee"
		},
		"SQL_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "Lochan_ADF_Project"
		},
		"customer_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://raw.githubusercontent.com"
		},
		"project_lochan_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "lochansql1.database.windows.net"
		},
		"project_lochan_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "pocdata"
		},
		"project_lochan_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "Lochan"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "PracticeADFprojects_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"AzureBlobStorage1_connectionString": {
						"value": "[parameters('AzureBlobStorage1_connectionString')]"
					},
					"AzureDataLakeStorage1_accountKey": {
						"value": "[parameters('AzureDataLakeStorage1_accountKey')]"
					},
					"project_lochan_password": {
						"value": "[parameters('project_lochan_password')]"
					},
					"SQL_password": {
						"value": "[parameters('SQL_password')]"
					},
					"AzureDataLakeStorage1_properties_typeProperties_url": {
						"value": "[parameters('AzureDataLakeStorage1_properties_typeProperties_url')]"
					},
					"customer_properties_typeProperties_url": {
						"value": "[parameters('customer_properties_typeProperties_url')]"
					},
					"project_lochan_properties_typeProperties_server": {
						"value": "[parameters('project_lochan_properties_typeProperties_server')]"
					},
					"project_lochan_properties_typeProperties_database": {
						"value": "[parameters('project_lochan_properties_typeProperties_database')]"
					},
					"project_lochan_properties_typeProperties_userName": {
						"value": "[parameters('project_lochan_properties_typeProperties_userName')]"
					},
					"SQL_properties_typeProperties_server": {
						"value": "[parameters('SQL_properties_typeProperties_server')]"
					},
					"SQL_properties_typeProperties_database": {
						"value": "[parameters('SQL_properties_typeProperties_database')]"
					},
					"SQL_properties_typeProperties_userName": {
						"value": "[parameters('SQL_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}